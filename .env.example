# Copy this file to .env and fill in your keys.
# .env is in .gitignore — it will NEVER be committed.
#
# GEMINI_API_KEY
#   Used by: scripts/nanobanana.py (schematic generation)
#   Get one: https://aistudio.google.com/app/apikey
#   Free tier available; no billing required to start.
GEMINI_API_KEY=your_gemini_key_here

# EDISON_API_KEY
#   Used by: scripts/lit_search.py (literature search)
#   Get one: https://platform.edisonscientific.com  (account → API keys)
#   Requires an Edison Scientific account.
EDISON_API_KEY=your_edison_key_here
